forgit() {
  local dir

  for dir in */; do
    [ -d "$dir" ] || continue
    (
      cd "$dir" || exit 1
      echo -e "----$dir-----"
      git "$@"
    )
  done
}


recursive_replace()
{
  local scope search replace

  if [ $# -eq 2 ]; then
    scope="./"
    search="$1"
    replace="$2"
  elif [ $# -eq 3 ]; then
    scope="$1"
    search="$2"
    replace="$3"
  else
    echo -e "Illegal number of arguments"
    return 1
  fi

  if [ ! -e "$scope" ]; then
    echo -e "Path not found: $scope"
    return 1
  fi

  grep -rFlZ --exclude-dir='.git' -- "$search" "$scope" |
    xargs -0r env SEARCH="$search" REPLACE="$replace" perl -0pi -e 's/\Q$ENV{SEARCH}\E/$ENV{REPLACE}/g'
}

