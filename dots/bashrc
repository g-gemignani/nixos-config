update_all() {
  local current_dir sys_count user_count answer safe_gen do_upgrade
  local host_name active_dm target_gdm target_sddm target_default_session use_boot_workflow

  do_upgrade=0
  use_boot_workflow=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --upgrade)
        do_upgrade=1
        ;;
      -h|--help)
        cat <<'EOF'
Usage: update_all [--upgrade]

  --upgrade  Run `nix flake update` before rebuilding.
EOF
        return 0
        ;;
      *)
        echo "Unknown option: $1"
        echo "Usage: update_all [--upgrade]"
        return 1
        ;;
    esac
    shift
  done

  current_dir=$(pwd)

  # Require sudo upfront
  sudo -v || return 1

  # ── 0. Show current state before doing anything ──────────────────────────
  echo -e "\n=== Current system generations ==="
  sudo nix-env --list-generations --profile /nix/var/nix/profiles/system
  safe_gen=$(sudo nix-env --list-generations --profile /nix/var/nix/profiles/system \
    | grep current | awk '{print $1}')
  echo -e "\n>>> Safe/current generation: $safe_gen (will never be deleted) <<<\n"

  # ── 1. Optionally update flake ───────────────────────────────────────────
  cd "$NIX_DIR" || return 1
  if [ "$do_upgrade" -eq 1 ]; then
    echo -e "\nUpdating Nix flake..."
    if ! nix flake update; then
      echo "nix flake update failed"
      cd "$current_dir"; return 1
    fi
  else
    echo -e "\nSkipping flake update (pass --upgrade to refresh flake.lock)."
  fi

  host_name=$(hostname)
  active_dm=$(systemctl show -P ExecStart display-manager.service 2>/dev/null || true)
  target_gdm=$(nix eval --json ".#nixosConfigurations.${host_name}.config.services.displayManager.gdm.enable" 2>/dev/null || echo false)
  target_sddm=$(nix eval --json ".#nixosConfigurations.${host_name}.config.services.displayManager.sddm.enable" 2>/dev/null || echo false)
  target_default_session=$(nix eval --raw ".#nixosConfigurations.${host_name}.config.services.displayManager.defaultSession" 2>/dev/null || echo "")

  if [[ -n "${WAYLAND_DISPLAY:-}${DISPLAY:-}" ]]; then
    if [[ "$active_dm" == *"/sddm"* && "$target_gdm" == "true" ]] || \
       [[ "$active_dm" == *"/gdm"* && "$target_sddm" == "true" ]]; then
      use_boot_workflow=1
    fi
  fi

  # ── 2. Copy config to /etc/nixos ─────────────────────────────────────────
  echo -e "\nCopying Nix files to /etc/nixos/..."
  if ! sudo cp -r ./* /etc/nixos/; then
    echo "copy to /etc/nixos failed"
    cd "$current_dir"; return 1
  fi

  # ── 3. Build using the safest activation strategy for the current session ─
  if [ "$use_boot_workflow" -eq 1 ]; then
    echo -e "\nBuilding new configuration without live activation..."
    echo "Detected a display-manager change while running inside a graphical session."
    echo "Skipping 'nixos-rebuild test' to avoid tearing down the current desktop."
    if [ -n "$target_default_session" ]; then
      echo "Target default session: $target_default_session"
    fi
    if ! sudo nixos-rebuild build --show-trace; then
      echo ""
      echo "nixos-rebuild build failed. Your running system is still on generation $safe_gen."
      cd "$current_dir"; return 1
    fi

    echo ""
    echo "Build succeeded. The new graphical stack was not activated in this session."
    read -r -p "Install this as the next boot generation instead? [y/N] " answer
    case "$answer" in
      [yY][eE][sS]|[yY])
        if ! sudo nixos-rebuild boot --show-trace; then
          echo "nixos-rebuild boot failed. Rebooting will keep generation $safe_gen."
          cd "$current_dir"; return 1
        fi
        echo ""
        echo "The new generation will be used on next reboot."
        echo "Reboot to test the new display-manager/session stack safely."
        cd "$current_dir"
        return 0
        ;;
      *)
        echo ""
        echo "Build completed, but the current boot generation remains unchanged."
        cd "$current_dir"
        return 0
        ;;
    esac
  fi

  echo -e "\nBuilding and testing new configuration..."
  echo "NOTE: If this fails or the desktop breaks, just reboot — the previous generation is safe."
  if ! sudo nixos-rebuild test --show-trace; then
    echo ""
    echo "nixos-rebuild test failed. No changes have been made to your boot configuration."
    echo "Your system is still on generation $safe_gen."
    cd "$current_dir"; return 1
  fi

  # ── 4. Confirm before making it the boot default ─────────────────────────
  echo ""
  echo "Build succeeded and new config is now active in this session."
  echo "Check that everything works (display manager, apps, etc.) before continuing."
  echo ""
  read -r -p "Make this the default boot generation? [y/N] " answer
  case "$answer" in
    [yY][eE][sS]|[yY])
      if ! sudo nixos-rebuild switch --show-trace; then
        echo "nixos-rebuild switch failed. Rebooting will return you to generation $safe_gen."
        cd "$current_dir"; return 1
      fi
      ;;
    *)
      echo ""
      echo "Keeping generation $safe_gen as boot default."
      echo "The new config is active in this session only — reboot to go back to gen $safe_gen."
      cd "$current_dir"
      return 0
      ;;
  esac

  # ── 5. Show new generation state ─────────────────────────────────────────
  echo -e "\n=== Updated system generations ==="
  sudo nix-env --list-generations --profile /nix/var/nix/profiles/system
  local new_gen
  new_gen=$(sudo nix-env --list-generations --profile /nix/var/nix/profiles/system \
    | grep current | awk '{print $1}')
  echo -e "\n>>> New current generation: $new_gen | Previous safe generation was: $safe_gen <<<"

  # ── 6. Clean up old generations (never touches current) ──────────────────
  cd "$current_dir" || return 1
  echo -e "\nCleaning up old system generations (keeping latest 10)..."
  sys_count=$(sudo nix-env --list-generations --profile /nix/var/nix/profiles/system \
    2>/dev/null | wc -l | tr -d ' ')
  [ -z "$sys_count" ] && sys_count=0

  if [ "$sys_count" -gt 10 ]; then
    echo "Found $sys_count system generations — deleting oldest, keeping latest 10."
    echo "Note: the current generation ($new_gen) is always protected."
    sudo nix-env --profile /nix/var/nix/profiles/system --delete-generations +10
  else
    echo "Only $sys_count system generations present — skipping cleanup."
  fi

  echo -e "\nCleaning up old user generations (keeping latest 10)..."
  user_count=$(nix-env --list-generations 2>/dev/null | wc -l | tr -d ' ')
  [ -z "$user_count" ] && user_count=0

  if [ "$user_count" -gt 10 ]; then
    echo "Found $user_count user generations — deleting oldest, keeping latest 10."
    nix-env --delete-generations +10
  else
    echo "Only $user_count user generations present — skipping cleanup."
  fi

  # ── 7. Garbage collection — only after confirming new gen is stable ───────
  echo ""
  echo "WARNING: Garbage collection removes unreferenced store paths permanently."
  echo "Only run this after you have confirmed the new generation ($new_gen) is fully working."
  echo "If unsure, skip and run 'sudo nix-collect-garbage -d' manually later."
  echo ""
  read -r -p "Run full garbage collection now? [y/N] " answer
  case "$answer" in
    [yY][eE][sS]|[yY])
      sudo nix-collect-garbage -d
      ;;
    *)
      echo "Skipping garbage collection. Run it manually once you're confident the new generation is stable."
      ;;
  esac

  echo -e "\nUpdate complete! Current generation: $new_gen"
}

validate_nix_config() {
  local current_dir

  current_dir=$(pwd)
  cd "$NIX_DIR" || return 1

  echo -e "\nChecking shell scripts..."
  bash -n install.sh || {
    cd "$current_dir" || return 1
    return 1
  }
  bash -n dots/bashrc || {
    cd "$current_dir" || return 1
    return 1
  }

  echo -e "\nChecking flake outputs..."
  nix flake check || {
    cd "$current_dir" || return 1
    return 1
  }

  echo -e "\nChecking compatibility entrypoints..."
  nix-instantiate --eval default.nix >/dev/null || {
    cd "$current_dir" || return 1
    return 1
  }
  nix-instantiate --eval shell.nix >/dev/null || {
    cd "$current_dir" || return 1
    return 1
  }

  cd "$current_dir" || return 1
  echo -e "Validation complete!"
}

alias update-all='update_all'
alias validate-nix-config='validate_nix_config'

